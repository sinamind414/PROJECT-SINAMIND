# ═══ BASE DE DONNÉES ═══════════════════
POSTGRES_USER=khawarizmi_user
POSTGRES_PASSWORD=__CHANGE_ME_IN_PROD__
POSTGRES_DB=khawarizmi
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# ═══ REDIS ══════════════════════════════
REDIS_URL=redis://redis:6379/0

# ═══ IA — CLÉS API ══════════════════════
# Option 1 : Gemini (via OpenAI-compatible endpoint)
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_API_KEY=your_google_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
OPENAI_MODEL=gemini-2.5-flash

# Option 2 : OpenAI direct
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# Fallback providers
ANTHROPIC_API_KEY=your_anthropic_key_here
GROQ_API_KEY=your_groq_key_here

# ═══ IA — VISION (Dual Coding) ══════════
# Clé séparée pour la vision (peut être OpenAI, Gemini, etc.)
# Si vide, le dual coding retourne un message gracieux
VISION_API_KEY=
VISION_BASE_URL=https://api.openai.com/v1
VISION_MODEL=gpt-4o-mini

# ═══ IA — Z.AI / GLM-4.7 (Fallback IA) ═══
# Gratuit : glm-4.7-flash | Payant : glm-4.7 ($0.60/M input)
# https://z.ai/manage-apikey
ZAI_API_KEY=your_zai_api_key_here
ZAI_MODEL=glm-4.7

# ═══ AUTH JWT ════════════════════════════
# Générer avec : python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=CHANGE_ME_GENERATE_WITH_SECRETS_TOKEN_HEX_64
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ═══ PAIEMENT ═══════════════════════════
CHARGILY_SECRET_KEY=test_sk_fake

# ═══ APP ════════════════════════════════
ENVIRONMENT=development
DATA_DIR=/app
