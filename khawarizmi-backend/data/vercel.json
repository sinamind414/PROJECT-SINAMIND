{
  "name": "khawarizmi",
  "version": 2,

  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],

  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/app.js",
      "dest": "/app.js"
    },
    {
      "src": "/translations.js",
      "dest": "/translations.js"
    },
    {
      "src": "/index.css",
      "dest": "/index.css"
    },
    {
      "src": "/KHAWARIZMI.png",
      "dest": "/KHAWARIZMI.png"
    },
    {
      "src": "/(.*)\\.json",
      "dest": "/$1.json"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],

  "headers": [

    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self' https:;"
        }
      ]
    },

    {
      "source": "/index.css",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, stale-while-revalidate=3600"
        }
      ]
    },
    {
      "source": "/app.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, stale-while-revalidate=3600"
        }
      ]
    },
    {
      "source": "/translations.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, stale-while-revalidate=3600"
        }
      ]
    },

    {
      "source": "/KHAWARIZMI.png",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=2592000, immutable"
        }
      ]
    },

    {
      "source": "/(.*)\\.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    },

    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ],

  "redirects": [
    {
      "source": "/home",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/index",
      "destination": "/",
      "permanent": true
    }
  ],

  "cleanUrls": true,
  "trailingSlash": false
}
