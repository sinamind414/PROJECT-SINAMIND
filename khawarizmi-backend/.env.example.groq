# Khawarizmi Pro – .env Groq (test)
SECRET_KEY=change-me-min-16-chars-xxxxxxxx
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost/khawarizmi
REDIS_URL=redis://localhost:6379/0
ENVIRONMENT=development

# IA – Groq primary
OPENAI_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx
