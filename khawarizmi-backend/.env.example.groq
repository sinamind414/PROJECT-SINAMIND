CLOUDFLARE_ACCOUNT_ID=

AI_MODEL_PRIMARY=llama-3.3-70b-versatile
ia_temperature=0.3
ia_max_tokens=600
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
