# Exclude frontend (not needed in backend image)
khawarizmi-frontend/

# Exclude heavy data (use JSON fallback at runtime)
khawarizmi-backend/data/ANNALES_SVT_BAC_ALGERIE/
khawarizmi-backend/data/annales_workspace/
khawarizmi-backend/data/ocr_production/
khawarizmi-backend/data/ocr_test_prod/
khawarizmi-backend/data/ocr_livre_scolaire/
khawarizmi-backend/data/ocr_output/

# Fallback programme critique, ne jamais exclure
!khawarizmi-backend/data/
!khawarizmi-backend/data/programmes/
!khawarizmi-backend/data/programmes/**

# Python
**/__pycache__/
**/*.pyc
**/.pytest_cache/

# Env
**/.env
**/.env.*

# IDE
**/.vscode/
**/.idea/
