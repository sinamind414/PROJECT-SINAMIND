# Dockerignore pour Railway build (root context)
# Le Dockerfile COPY khawarizmi-backend/ . depuis la racine

# Données lourdes à exclure
khawarizmi-backend/data/ANNALES_SVT_BAC_ALGERIE/
khawarizmi-backend/data/annales_workspace/
khawarizmi-backend/data/ocr_production/
khawarizmi-backend/data/ocr_test_prod/
khawarizmi-backend/data/ocr_livre_scolaire/
khawarizmi-backend/data/ocr_output/

# Python
**/__pycache__/
**/*.pyc
**/*.pyo
**/.pytest_cache/
**/.coverage

# Git
**/.git
**/.gitignore

# Env
**/.env
**/.env.*

# IDE
**/.vscode/
**/.idea/

# Node (frontend)
khawarizmi-frontend/node_modules/
khawarizmi-frontend/.next/
khawarizmi-frontend/dist/
khawarizmi-frontend/.expo/

# Models lourds
**/models/*.onnx
**/models/*.zip
**/models/*.pt
**/models/*.pth
**/models/*.bin
**/*.zip
**/*.tar.gz
**/*.bundle

# Logs
**/*.log
**/logs/

# Backups
**/.backup_*
**/*.backup_*

# Dockerfiles
**/Dockerfile
**/.dockerignore
