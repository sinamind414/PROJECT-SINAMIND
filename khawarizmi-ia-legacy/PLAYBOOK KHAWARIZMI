-- Niveaux de maîtrise par chapitre
CREATE TABLE mastery_levels (
    id              UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    user_id         UUID REFERENCES users(id),
    matiere         VARCHAR(50),
    chapitre        VARCHAR(200),

    -- Score actuel (moyenne des 10 derniers exercices)
    score_actuel    FLOAT DEFAULT 0.0,

    -- Niveau 0-4
    niveau          INTEGER DEFAULT 0,

    -- Historique pour valider le niveau 4 (3 jours à 90%+)
    jours_excellence INTEGER DEFAULT 0,
    derniere_excellence TIMESTAMP,

    -- SM-2 intégré
    easiness_factor FLOAT DEFAULT 2.5,
    interval_jours  INTEGER DEFAULT 1,
    prochaine_revision TIMESTAMP DEFAULT NOW(),

    updated_at      TIMESTAMP DEFAULT NOW(),
    UNIQUE(user_id, matiere, chapitre)
);

-- Fonction de mise à jour du niveau de maîtrise
CREATE OR REPLACE FUNCTION update_mastery(
    p_user_id UUID,
    p_matiere VARCHAR,
    p_chapitre VARCHAR,
    p_new_score FLOAT
) RETURNS INTEGER AS $$
DECLARE
    current_avg FLOAT;
    new_level INTEGER;
BEGIN
    -- Calculer la moyenne glissante (derniers 10 exercices)
    SELECT AVG(score) INTO current_avg
    FROM (
        SELECT score
        FROM exercise_results
        WHERE user_id = p_user_id
          AND matiere = p_matiere
          AND chapitre = p_chapitre
        ORDER BY created_at DESC
        LIMIT 10
    ) recent;

    -- Déterminer le niveau
    IF current_avg IS NULL OR current_avg < 0.40 THEN
        new_level := 1;
    ELSIF current_avg < 0.70 THEN
        new_level := 2;
    ELSIF current_avg < 0.90 THEN
        new_level := 3;
    ELSE
        new_level := 4;
    END IF;

    -- Mettre à jour
    INSERT INTO mastery_levels
        (user_id, matiere, chapitre, score_actuel, niveau)
    VALUES
        (p_user_id, p_matiere, p_chapitre, current_avg, new_level)
    ON CONFLICT (user_id, matiere, chapitre)
    DO UPDATE SET
        score_actuel = current_avg,
        niveau = new_level,
        updated_at = NOW();

    RETURN new_level;
END;
$$ LANGUAGE plpgsql;
