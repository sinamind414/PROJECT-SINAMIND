// referral.service.ts â€” SystÃ¨me de parrainage
export class ReferralService {
    static generateCode(userId: string): string {
        const chars   = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789';
        const segment = Array.from({ length: 4 }, () => chars[Math.floor(Math.random() * chars.length)]).join('');
        return `KHAW-${segment}`;
    }

    static async applyReferral(newUserId: string, referralCode: string, db: any) {
        const referrer = await db.query(`SELECT id, referral_count FROM users WHERE referral_code = $1`, [referralCode]);
        if (!referrer.rows.length) throw new Error('CODE_INVALIDE');

        const referrerId = referrer.rows[0].id;
        const newCount   = referrer.rows[0].referral_count + 1;

        await db.query(`INSERT INTO referrals (referrer_id, referred_id, code_used, created_at) VALUES ($1, $2, $3, NOW())`, [referrerId, newUserId, referralCode]);
        await this.addPremiumDays(newUserId, 14, db);
        await this.rewardReferrer(referrerId, newCount, db);

        return { success: true, bonusDays: 14 };
    }

    static async rewardReferrer(referrerId: string, totalReferrals: number, db: any) {
        let bonusDays = 7;
        if (totalReferrals === 3)  bonusDays = 30;
        if (totalReferrals === 5)  bonusDays = 90;
        if (totalReferrals === 10) bonusDays = 36500;

        await this.addPremiumDays(referrerId, bonusDays, db);
    }

    static async addPremiumDays(userId: string, days: number, db: any) {
        await db.query(`
            UPDATE users
            SET subscription_status = 'active',
                subscription_end = GREATEST(NOW(), COALESCE(subscription_end, NOW())) + INTERVAL '${days} days',
                updated_at = NOW()
            WHERE id = $1
        `, [userId]);
    }
}

