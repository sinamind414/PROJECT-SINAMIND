// Système d'alerte automatique (via email ou notification)
function getUpcomingDeadlines(daysAhead: number = 15): FiscalDeadline[] {
    const today   = new Date();
    const upcoming = [];

    for (const deadline of CALENDRIER_FISCAL_EURL) {
        const deadlineDate = new Date(
            today.getFullYear(),
            (deadline.mois || today.getMonth() + 1) - 1,
            deadline.jour
        );
        const daysUntil = Math.floor(
            (deadlineDate.getTime() - today.getTime()) / 86400000
        );

        if (daysUntil >= 0 && daysUntil <= daysAhead) {
            upcoming.push({ ...deadline, daysUntil });
        }
    }
    return upcoming;
}
