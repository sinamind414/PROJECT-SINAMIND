// financial-model.ts â€” Moteur de calcul du modÃ¨le financier

interface MonthlyInputs {
    newFreeUsers:        number;   // Nouveaux inscrits gratuits
    conversionRate:      number;   // % gratuit â†’ payant
    churnRate:           number;   // % annulation/mois
    arpu:                number;   // Revenu moyen par payant (DZD)
    variableCostPerUser: number;   // CoÃ»t IA + infra par user (DZD)
    fixedCosts:          number;   // CoÃ»ts fixes du mois (DZD)
}

interface MonthlyOutput {
    totalFreeUsers:   number;
    newPayingUsers:   number;
    totalPayingUsers: number;
    mrr:              number;
    revenue:          number;
    variableCosts:    number;
    totalCosts:       number;
    grossProfit:      number;
    grossMargin:      number;   // %
    cumulativeProfit: number;
}

class FinancialModel {

    static simulate(
        months:         number,
        inputs:         MonthlyInputs[],
        initialCash:    number = 300_000  // DZD de dÃ©part
    ): MonthlyOutput[] {

        const results: MonthlyOutput[] = [];
        let cumulativeProfit  = 0;
        let prevFreeUsers     = 0;
        let prevPayingUsers   = 0;

        for (let m = 0; m < months; m++) {
            const inp = inputs[m] || inputs[inputs.length - 1];

            // Utilisateurs gratuits
            const retainedFree  = Math.floor(prevFreeUsers * 0.40);
            const totalFreeUsers = retainedFree + inp.newFreeUsers;

            // Nouveaux payants (conversion des gratuits)
            const newPayingUsers = Math.floor(
                totalFreeUsers * inp.conversionRate
            );

            // Payants totaux (rÃ©tention + nouveaux)
            const retainedPaying = Math.floor(
                prevPayingUsers * (1 - inp.churnRate)
            );
            const totalPayingUsers = retainedPaying + newPayingUsers;

            // Revenus
            const mrr     = totalPayingUsers * inp.arpu;
            const revenue = mrr;

            // CoÃ»ts
            const variableCosts = totalFreeUsers * inp.variableCostPerUser;
            const totalCosts    = variableCosts + inp.fixedCosts;

            // Profit
            const grossProfit  = revenue - totalCosts;
            const grossMargin  = revenue > 0
                ? (grossProfit / revenue) * 100
                : -100;
            cumulativeProfit  += grossProfit;

            results.push({
                totalFreeUsers,
                newPayingUsers,
                totalPayingUsers,
                mrr,
                revenue,
                variableCosts,
                totalCosts,
                grossProfit,
                grossMargin:      parseFloat(grossMargin.toFixed(1)),
                cumulativeProfit,
            });

            prevFreeUsers   = totalFreeUsers;
            prevPayingUsers = totalPayingUsers;
        }

        return results;
    }

    // â”€â”€â”€ ScÃ©nario RÃ©aliste â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    static realisticScenario(): MonthlyOutput[] {

        const baseInputs: MonthlyInputs = {
            newFreeUsers:        300,
            conversionRate:      0.08,
            churnRate:           0.25,
            arpu:                950,
            variableCostPerUser: 8,
            fixedCosts:          7_900,
        };

        // Croissance progressive mois par mois
        const inputs: MonthlyInputs[] = Array.from(
            { length: 24 },
            (_, i) => ({
                ...baseInputs,
                newFreeUsers: Math.floor(
                    baseInputs.newFreeUsers * Math.pow(1.25, i)
                ),
                fixedCosts: i < 4  ? 7_900
                          : i < 12 ? 43_300
                          :           315_000,
            })
        );

        return this.simulate(24, inputs);
    }

    // â”€â”€â”€ Formatage pour affichage â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    static printTable(results: MonthlyOutput[]): void {

        console.log(
            'MOIS â”‚ USERS TOTAL â”‚ PAYANTS â”‚ MRR (DZD)   â”‚' +
            ' COÃ›TS (DZD) â”‚ PROFIT (DZD) â”‚ MARGE'
        );
        console.log('â”€'.repeat(80));

        results.forEach((r, i) => {
            const profit = r.grossProfit >= 0
                ? `+${r.grossProfit.toLocaleString()}`
                : r.grossProfit.toLocaleString();

            console.log(
                ` ${String(i + 1).padStart(2, '0')}  â”‚` +
                ` ${String(r.totalFreeUsers).padStart(11)} â”‚` +
                ` ${String(r.totalPayingUsers).padStart(7)} â”‚` +
                ` ${String(r.mrr).padStart(11)} â”‚` +
                ` ${String(r.totalCosts).padStart(11)} â”‚` +
                ` ${profit.padStart(12)} â”‚` +
                ` ${r.grossMargin}%`
            );
        });
    }
}

