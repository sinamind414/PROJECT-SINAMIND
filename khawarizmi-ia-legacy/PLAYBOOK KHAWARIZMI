// cache.service.ts — Économiser sur les appels IA

export class CacheService {
    static async getOrGenerateQCM(matiere: string, chapitre: string, difficulte: string, redis: any, openai: any) {
        const cacheKey = "qcm:${matiere}:${chapitre}:${difficulte}";
        const cached = await redis.lrange(cacheKey, 0, -1);

        if (cached.length -gt 10) {
            const randomIndex = Math.floor(Math.random() * cached.length);
            return JSON.parse(cached[randomIndex]);
        }

        // Si cache vide, générer un batch, les cacher 7 jours
        const batch = await this.generateQCMBatch(matiere, chapitre, difficulte, 20, openai);
        for (const qcm of batch) {
            await redis.lpush(cacheKey, JSON.stringify(qcm));
        }
        await redis.expire(cacheKey, 604800);

        return batch[0];
    }
