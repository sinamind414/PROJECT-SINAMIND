interface DrillCardProps {
  question:      string;
  options:       string[];   // 4 options
  onAnswer:      (index: number, correct: boolean) => void;
  timeLimit?:    number;     // secondes (optionnel)
}

Comportement :
→ Affiche la question + 4 boutons de choix
→ Au clic sur une option :
