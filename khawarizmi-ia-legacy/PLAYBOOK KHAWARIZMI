        for (const [id, badge] of Object.entries(this.BADGES)) {
            if (!earnedIds.includes(id) && badge.condition(userStats)) {
                // Nouveau badge !
                await db.query(`
                    INSERT INTO user_badges (user_id, badge_id, earned_at)
                    VALUES ($1, $2, NOW())
                `, [userId, id]);

                // Déclencher notification "Nouveau badge !"
                await this.triggerBadgeNotification(userId, badge, db);
            }
        }
    }
}
