        const lastActive = new Date(user.rows[0].last_active);
        const today = new Date();
        const diffDays = Math.floor(
            (today - lastActive) / (1000 * 60 * 60 * 24)
        );

        if (diffDays === 1) {
            // Hier → aujourd'hui = streak continue
            const newStreak = user.rows[0].streak_days + 1;
            await db.query(`
                UPDATE users
                SET streak_days = $1, last_active = NOW()
                WHERE id = $2
            `, [newStreak, userId]);

